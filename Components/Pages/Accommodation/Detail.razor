@page "/accommodations/{id:int}/detail"
@using BlazorProject.Data
@using Accommodation = BlazorProject.Data.Accommodation
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext _ApplicationDbContext
@rendermode InteractiveServer

<PageTitle>Accommodatie details</PageTitle>

@if (accommodation == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>@accommodation.Name</h1>
        <div>
            <a class="btn btn-warning" href="/accommodations/@accommodation.AccommodationID">Bewerken</a>
            <a class="btn btn-secondary ms-2" href="/">Terug</a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(accommodation.ImageURL))
    {
        <img src="@accommodation.ImageURL" class="img-fluid mb-3 rounded" style="max-height:300px;" alt="@accommodation.Name" />
    }

    <dl class="row">
        <dt class="col-sm-3">Beschrijving</dt>
        <dd class="col-sm-9">@(accommodation.Description ?? "-")</dd>

        <dt class="col-sm-3">Prijs</dt>
        <dd class="col-sm-9">@(accommodation.Price.HasValue ? "€" + accommodation.Price.Value.ToString("0.00") : "-")</dd>

        <dt class="col-sm-3">Locatie</dt>
        <dd class="col-sm-9">
            @if (accommodation.Location != null)
            {
                @accommodation.Location.City@(", ")@accommodation.Location.Province@(", ")@accommodation.Location.Country
            }
            else
            {
                <span>-</span>
            }
        </dd>
    </dl>

    @if (accommodation.AccommodationProperties.Any())
    {
        <h4 class="mt-4">Eigenschappen</h4>
        <table class="table table-sm table-bordered">
            <thead>
                <tr>
                    <th>Eigenschap</th>
                    <th>Waarde</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ap in accommodation.AccommodationProperties)
                {
                    <tr>
                        <td>@ap.Property?.Name</td>
                        <td>@ap.Value</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    [Parameter] public int Id { get; set; }

    private Accommodation? accommodation;

    protected override async Task OnInitializedAsync()
    {
        accommodation = await _ApplicationDbContext.Accommodations
            .Include(a => a.Location)
            .Include(a => a.AccommodationProperties)
                .ThenInclude(ap => ap.Property)
            .FirstOrDefaultAsync(a => a.AccommodationID == Id);
    }
}
