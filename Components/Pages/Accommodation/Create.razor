@page "/accommodations/create"
@using BlazorProject.Data
@using Accommodation = BlazorProject.Data.Accommodation
@using Location = BlazorProject.Data.Location
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext _ApplicationDbContext
@rendermode InteractiveServer
@inject NavigationManager Navigation

<PageTitle>Accommodatie toevoegen</PageTitle>

<h1>Accommodatie toevoegen</h1>

<EditForm Model=@newAccommodation OnValidSubmit="HandleValidSubmit" FormName="createAccommodationForm">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label">Naam:</label>
        <InputText @bind-Value=newAccommodation.Name class="form-control" placeholder="Naam..." />
    </div>

    <div class="mb-3">
        <label class="form-label">Beschrijving:</label>
        <InputTextArea @bind-Value=newAccommodation.Description class="form-control" rows="3" placeholder="Beschrijving..." />
    </div>

    <div class="mb-3">
        <label class="form-label">Prijs (€):</label>
        <InputNumber @bind-Value=newAccommodation.Price class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Afbeelding URL:</label>
        <InputText @bind-Value=newAccommodation.ImageURL class="form-control" placeholder="https://..." />
    </div>

    <div class="mb-3">
        <label class="form-label">Locatie:</label>
        <InputSelect @bind-Value=newAccommodation.LocationID class="form-control">
            <option value="0">-- Selecteer locatie --</option>
            @foreach (var location in locations ?? [])
            {
                <option value="@location.LocationID">@location.City, @location.Country</option>
            }
        </InputSelect>
    </div>

    <input type="submit" value="Opslaan" class="btn btn-success" />
    <a href="/" class="btn btn-secondary ms-2">Annuleren</a>
</EditForm>

@code {
    private Location[]? locations;

    [SupplyParameterFromForm]
    private Accommodation newAccommodation { get; set; } = new Accommodation();

    protected override async Task OnInitializedAsync()
    {
        locations = await _ApplicationDbContext.Locations.ToArrayAsync();
    }

    private async Task HandleValidSubmit()
    {
        _ApplicationDbContext.Accommodations.Add(newAccommodation);
        await _ApplicationDbContext.SaveChangesAsync();
        Navigation.NavigateTo("/");
    }
}
