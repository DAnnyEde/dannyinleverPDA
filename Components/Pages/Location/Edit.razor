@page "/locations/{id:int}"
@using BlazorProject.Data
@using Location = BlazorProject.Data.Location
@inject ApplicationDbContext _ApplicationDbContext
@rendermode InteractiveServer
@inject NavigationManager Navigation

<PageTitle>Locatie bewerken</PageTitle>

@if (location == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Locatie bewerken</h1>
        <button class="btn btn-danger" @onclick="DeleteLocation">Verwijderen</button>
    </div>

    <EditForm Model=@location OnValidSubmit="HandleValidSubmit" FormName="editLocationForm">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label class="form-label">Stad:</label>
            <InputText @bind-Value=location.City class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Provincie:</label>
            <InputText @bind-Value=location.Province class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Land:</label>
            <InputText @bind-Value=location.Country class="form-control" />
        </div>

        <input type="submit" value="Opslaan" class="btn btn-success" />
        <a href="/locations/" class="btn btn-secondary ms-2">Annuleren</a>
    </EditForm>
}

@code {
    [Parameter] public int Id { get; set; }

    private Location? location;

    protected override async Task OnInitializedAsync()
    {
        location = await _ApplicationDbContext.Locations.FindAsync(Id);
    }

    private async Task HandleValidSubmit()
    {
        _ApplicationDbContext.Locations.Update(location!);
        await _ApplicationDbContext.SaveChangesAsync();
        Navigation.NavigateTo("/locations/");
    }

    private async Task DeleteLocation()
    {
        var accIds = _ApplicationDbContext.Accommodations
            .Where(a => a.LocationID == Id)
            .Select(a => a.AccommodationID);

        var bookings = _ApplicationDbContext.Bookings.Where(b => accIds.Contains(b.AccommodationID));
        _ApplicationDbContext.Bookings.RemoveRange(bookings);

        var accProps = _ApplicationDbContext.AccommodationProperties.Where(ap => accIds.Contains(ap.AccommodationID));
        _ApplicationDbContext.AccommodationProperties.RemoveRange(accProps);

        var accommodations = _ApplicationDbContext.Accommodations.Where(a => a.LocationID == Id);
        _ApplicationDbContext.Accommodations.RemoveRange(accommodations);

        _ApplicationDbContext.Locations.Remove(location!);
        await _ApplicationDbContext.SaveChangesAsync();
        Navigation.NavigateTo("/locations/");
    }
}
